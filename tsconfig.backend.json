{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "express", "multer"]
  },
  "include": ["src/server/**/*", "src/rag/**/*", "src/prompts/**/*", "src/db/**/*", "src/services/**/*", "src/utils/**/*", "src/shared/**/*"]
}
